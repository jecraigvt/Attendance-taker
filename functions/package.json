{
  "name": "attendance-taker-functions",
  "description": "Firebase Cloud Functions for Attendance Taker",
  "scripts": {
    "lint": "eslint .",
    "build": "echo 'No build step required'",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "cheerio": "^1.0.0",
    "fernet": "^0.4.0",
    "puppeteer": "^24.0.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0"
  },
  "private": true
}
